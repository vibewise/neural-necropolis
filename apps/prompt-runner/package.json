{
  "name": "@neural-necropolis/prompt-runner",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "types": "./src/index.ts",
  "description": "Hosted prompt runner control-plane service and reference worker for Neural Necropolis.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test ./test/**/*.test.mts",
    "serve": "tsx src/cli.ts serve",
    "worker": "tsx src/cli.ts worker"
  },
  "dependencies": {
    "@neural-necropolis/agent-sdk": "*",
    "@neural-necropolis/protocol-ts": "*",
    "dotenv": "^16.4.7",
    "openai": "^6.31.0"
  }
}

PORT=3000
BEAT_PLANNING_MS=12000
BEAT_ACTION_MS=500
BOARD_WARMUP_MS=0
DUNGEON_SEED=shadowkeep-alpha
MAX_HEROES=0
EXPECTED_HEROES=0
RESET_ON_BOOT=0
# Optional override. For local runs, either leave this unset
# or keep it aligned with PORT above.
NEURAL_NECROPOLIS_SERVER_URL=http://127.0.0.1:3000
NEURAL_NECROPOLIS_PLAYER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.neural-necropolis-dev-player.signature
NEURAL_NECROPOLIS_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.neural-necropolis-dev-admin.signature
# Optional shared fallback if you want one token for both:
# NEURAL_NECROPOLIS_AUTH_TOKEN=replace-me
RUNNER_POLL_MS=4000

# When `npm run run:scripted:agents` starts, it will try to set the
# server submit window to this value through the admin API first.
SCRIPTED_SUBMIT_WINDOW_MS=2000

# ─── Providers ──────────────────────────────────────
# DEFAULT_PROVIDER selects the provider for slots that say "default" or omit it.
# All providers below expose an OpenAI-compatible chat completions endpoint.
#
# Compatible providers (built-in URLs, just add an API key):
#   openai    — https://api.openai.com/v1
#   groq      — https://api.groq.com/openai/v1
#   together  — https://api.together.xyz/v1
#   fireworks — https://api.fireworks.ai/inference/v1
#   perplexity— https://api.perplexity.ai
#   ollama    — http://localhost:11434/v1  (local, no key needed)
#
# NOT compatible (require different SDKs, not supported here):
#   Anthropic — uses its own REST protocol
#   Google Gemini — has an experimental OpenAI-compat shim but not production-ready
#
# Override a built-in URL by setting <PROVIDER>_BASE_URL.

DEFAULT_PROVIDER=groq

GROQ_API_KEY=gsk-your-groq-key
# OPENAI_API_KEY=sk-your-openai-key
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# OLLAMA_API_KEY=ollama

# ─── Model Presets ──────────────────────────────────
# MODEL_<ALIAS>_ID   = actual model identifier sent to the API
# MODEL_<ALIAS>_*    = per-model tuning defaults
# Aliases are case-insensitive and referenced by bot slots below.

MODEL_LLAMA70_ID=llama-3.3-70b-versatile
MODEL_LLAMA70_TEMPERATURE=0.3
MODEL_LLAMA70_MAX_COMPLETION_TOKENS=180

MODEL_OSS120_ID=openai/gpt-oss-120b
MODEL_OSS120_TEMPERATURE=0.3
MODEL_OSS120_MAX_COMPLETION_TOKENS=280
MODEL_OSS120_INCLUDE_REASONING=false
MODEL_OSS120_REASONING_EFFORT=low

MODEL_OSS20_ID=openai/gpt-oss-20b
MODEL_OSS20_TEMPERATURE=0.3
MODEL_OSS20_MAX_COMPLETION_TOKENS=240
MODEL_OSS20_INCLUDE_REASONING=false
MODEL_OSS20_REASONING_EFFORT=low

MODEL_GPT4OMINI_ID=gpt-4o-mini
MODEL_GPT4OMINI_TEMPERATURE=0.4
MODEL_GPT4OMINI_MAX_COMPLETION_TOKENS=220

# ─── Bot Slots (A–J) ───────────────────────────────
# Each slot configures one AI bot instance.
# AIBOT_<SLOT>_PROVIDER = provider name or "default"
# AIBOT_<SLOT>_MODEL    = model alias from the preset section above
# Bot display name is auto-derived as <Provider>-<ModelAlias>-<Slot>.

# A — Groq Llama 70B, aggressive
AIBOT_A_PROVIDER=groq
AIBOT_A_MODEL=llama70
AIBOT_A_TRAIT=aggressive
AIBOT_A_MISSION=combat
AIBOT_A_INCLUDE_EXPLORED_MEMORY=true

# B — Groq OSS 120B, cautious
AIBOT_B_PROVIDER=groq
AIBOT_B_MODEL=oss120
AIBOT_B_TRAIT=cautious
AIBOT_B_MISSION=combat
AIBOT_B_INCLUDE_EXPLORED_MEMORY=true

# C — Groq OSS 20B, resilient
AIBOT_C_PROVIDER=groq
AIBOT_C_MODEL=oss20
AIBOT_C_TRAIT=resilient
AIBOT_C_MISSION=combat
AIBOT_C_INCLUDE_EXPLORED_MEMORY=true

# D — OpenAI GPT-4o Mini, curious
AIBOT_D_PROVIDER=openai
AIBOT_D_MODEL=gpt4omini
AIBOT_D_TRAIT=curious
AIBOT_D_MISSION=balanced
AIBOT_D_INCLUDE_EXPLORED_MEMORY=true

# E — Groq Llama 70B, greedy
AIBOT_E_PROVIDER=groq
AIBOT_E_MODEL=llama70
AIBOT_E_TRAIT=greedy
AIBOT_E_MISSION=escape
AIBOT_E_INCLUDE_EXPLORED_MEMORY=true

# F — Groq OSS 120B, cautious
AIBOT_F_PROVIDER=groq
AIBOT_F_MODEL=oss120
AIBOT_F_TRAIT=cautious
AIBOT_F_MISSION=balanced
AIBOT_F_INCLUDE_EXPLORED_MEMORY=true

# G — Groq Llama 70B, aggressive
AIBOT_G_PROVIDER=groq
AIBOT_G_MODEL=llama70
AIBOT_G_TRAIT=aggressive
AIBOT_G_MISSION=combat
AIBOT_G_INCLUDE_EXPLORED_MEMORY=true

# H — Groq OSS 20B, resilient
AIBOT_H_PROVIDER=groq
AIBOT_H_MODEL=oss20
AIBOT_H_TRAIT=resilient
AIBOT_H_MISSION=combat
AIBOT_H_INCLUDE_EXPLORED_MEMORY=true

# I — Groq OSS 120B, curious
AIBOT_I_PROVIDER=groq
AIBOT_I_MODEL=oss120
AIBOT_I_TRAIT=curious
AIBOT_I_MISSION=balanced
AIBOT_I_INCLUDE_EXPLORED_MEMORY=true

# J — Groq Llama 70B, greedy
AIBOT_J_PROVIDER=groq
AIBOT_J_MODEL=llama70
AIBOT_J_TRAIT=greedy
AIBOT_J_MISSION=escape
AIBOT_J_INCLUDE_EXPLORED_MEMORY=true

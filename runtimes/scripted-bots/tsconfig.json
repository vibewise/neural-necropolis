{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@neural-necropolis/agent-sdk": ["../../packages/agent-sdk/src/index.ts"],
      "@neural-necropolis/protocol-ts": [
        "../../packages/protocol-ts/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/agent-sdk/src/**/*.ts",
    "../../packages/protocol-ts/src/**/*.ts"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": "..",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@neural-necropolis/agent-sdk": ["../agent-sdk/src/index.ts"],
      "@neural-necropolis/protocol-ts": ["../protocol-ts/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../agent-sdk/src/**/*.ts",
    "../protocol-ts/src/**/*.ts"
  ]
}

{
  "name": "neural-necropolis",
  "version": "0.2.0",
  "private": true,
  "description": "Neural Necropolis — Where Dead Code Dreams of Vengeance. AI agents explore, fight, loot, and escape a procedurally generated dungeon.",
  "type": "module",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "runtimes/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:agent-sdk && npm run test:prompt-runner && npm run test:dashboard-app",
    "test:agent-sdk": "npm run test -w @neural-necropolis/agent-sdk",
    "test:prompt-runner": "npm run test -w @neural-necropolis/prompt-runner",
    "test:dashboard-app": "npm run test -w @neural-necropolis/dashboard-app",
    "build:agent-sdk": "npm run build -w @neural-necropolis/agent-sdk",
    "build:protocol-ts": "npm run build -w @neural-necropolis/protocol-ts",
    "build:dashboard-app": "npm run build -w @neural-necropolis/dashboard-app && node scripts/sync-dashboard-build.mjs",
    "build:scripted-bots": "npm run build -w @neural-necropolis/scripted-bots",
    "build:ai-bots": "npm run build -w @neural-necropolis/ai-bots",
    "build:openclaw-runner": "npm run build -w @neural-necropolis/openclaw-runner",
    "build:prompt-runner": "npm run build -w @neural-necropolis/prompt-runner",
    "validate:contract": "tsx scripts/validate-public-contract.ts",
    "validate:prompt-manifest": "tsx scripts/validate-prompt-manifest.ts",
    "validate:boundaries": "node scripts/validate-architecture-boundaries.mjs",
    "validate": "npm run validate:contract && npm run validate:prompt-manifest && npm run validate:boundaries && npm run test:prompt-runner && npm run test:dashboard-app",
    "run:prompt-runner": "npm run serve -w @neural-necropolis/prompt-runner",
    "run:dashboard:dev": "npm run dev -w @neural-necropolis/dashboard-app",
    "run:engine": "node scripts/run-engine.mjs",
    "run:engine:build": "node scripts/run-engine.mjs --build",
    "run:demo:local": "node scripts/run-demo-local.mjs",
    "run:demo:prompt-runner": "node scripts/run-demo-prompt-runner.mjs",
    "run:scripted:bot:berserker": "npm run run:berserker -w @neural-necropolis/scripted-bots",
    "run:scripted:bot:treasure": "npm run run:treasure-hunter -w @neural-necropolis/scripted-bots",
    "run:scripted:bot:explorer": "npm run run:explorer -w @neural-necropolis/scripted-bots",
    "run:scripted:agents": "node scripts/run-swarm.mjs scripted",
    "run:aibots:bot": "npm run run:bot -w @neural-necropolis/ai-bots",
    "run:aibots:agents": "node scripts/run-swarm.mjs aibots",
    "run:openclaw:onboard": "openclaw onboard --non-interactive --accept-risk --workspace . --skip-channels --skip-search --skip-ui --skip-skills --skip-health --no-install-daemon",
    "run:openclaw:gateway": "openclaw gateway run",
    "run:openclaw:bot": "npm run run:bot -w @neural-necropolis/openclaw-runner --",
    "run:openclaw:agents": "node scripts/run-openclaw-swarm.mjs",
    "run:openclaw:register": "npm run register -w @neural-necropolis/openclaw-runner --",
    "run:openclaw:bootstrap": "npm run bootstrap -w @neural-necropolis/openclaw-runner --",
    "run:openclaw:step": "npm run step -w @neural-necropolis/openclaw-runner --",
    "run:openclaw:act": "npm run act -w @neural-necropolis/openclaw-runner --",
    "run:openclaw:reset": "npm run reset -w @neural-necropolis/openclaw-runner --",
    "run:runner": "tsx watch scripts/runner.ts",
    "run:dev:all": "concurrently -k -n runner,berserker,treasure,explorer,aibot -c white,red,yellow,green,magenta \"npm run run:runner\" \"npm run run:scripted:bot:berserker\" \"npm run run:scripted:bot:treasure\" \"npm run run:scripted:bot:explorer\" \"npm run run:aibots:bot\"",
    "run:all": "npm run run:dev:all"
  },
  "dependencies": {
    "@neural-necropolis/agent-sdk": "*",
    "@neural-necropolis/protocol-ts": "*",
    "dotenv": "^16.4.7",
    "openai": "^6.31.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

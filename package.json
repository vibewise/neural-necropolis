{
  "name": "neural-necropolis",
  "version": "0.2.0",
  "private": true,
  "description": "Neural Necropolis — Where Dead Code Dreams of Vengeance. AI agents explore, fight, loot, and escape a procedurally generated dungeon.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "run:engine": "node scripts/run-engine.mjs",
    "run:engine:build": "node scripts/run-engine.mjs --build",
    "run:scripted:bot:berserker": "tsx watch src/agents/bots/berserker.ts",
    "run:scripted:bot:treasure": "tsx watch src/agents/bots/treasure-hunter.ts",
    "run:scripted:bot:explorer": "tsx watch src/agents/bots/explorer.ts",
    "run:scripted": "node scripts/run-swarm.mjs scripted",
    "run:aibots:bot": "tsx watch src/agents/bots/aibot.ts",
    "run:aibots": "node scripts/run-swarm.mjs aibots",
    "run:openclaw:onboard": "openclaw onboard --non-interactive --accept-risk --workspace . --skip-channels --skip-search --skip-ui --skip-skills --skip-health --no-install-daemon",
    "run:openclaw": "concurrently -k -n engine,gateway -c blue,magenta \"npm run run:engine\" \"openclaw gateway run\"",
    "run:openclaw:bot": "tsx src/agents/openclaw/autoplay.ts",
    "run:openclaw:swarm": "node scripts/run-openclaw-swarm.mjs",
    "run:openclaw:register": "tsx src/agents/openclaw/game-cli.ts register",
    "run:openclaw:bootstrap": "tsx src/agents/openclaw/game-cli.ts bootstrap",
    "run:openclaw:step": "tsx src/agents/openclaw/game-cli.ts step",
    "run:openclaw:act": "tsx src/agents/openclaw/game-cli.ts act",
    "run:openclaw:reset": "tsx src/agents/openclaw/game-cli.ts reset",
    "run:runner": "tsx watch src/runner.ts",
    "run:all": "concurrently -k -n engine,runner,berserker,treasure,explorer,aibot -c blue,white,red,yellow,green,magenta \"npm run run:engine\" \"npm run run:runner\" \"npm run run:scripted:bot:berserker\" \"npm run run:scripted:bot:treasure\" \"npm run run:scripted:bot:explorer\" \"npm run run:aibots:bot\""
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "openai": "^6.31.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
